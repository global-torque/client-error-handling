{
  "name": "@global-torque/client-error-handling",
  "private": false,
  "version": "0.1.0-beta.3",
  "description": "Transport-safe client error normalization, sanitization, and bounded reporting pipelines.",
  "keywords": [
    "errors",
    "privacy",
    "sanitization",
    "telemetry"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "sideEffects": false,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "node scripts/build.mjs",
    "lint": "eslint --max-warnings=0 src scripts vitest.config.ts",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.mjs\" \".github/**/*.{yml,json,md}\" \"docs/{rfcs,ossf}/**/*.md\" \"*.{json,md,yaml}\"",
    "format:write": "prettier --write \"src/**/*.ts\" \"scripts/**/*.mjs\" \".github/**/*.{yml,json,md}\" \"docs/{rfcs,ossf}/**/*.md\" \"*.{json,md,yaml}\"",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "api:check": "api-extractor run --verbose",
    "api:report:update": "pnpm run build && api-extractor run --local --verbose",
    "docs:api": "pnpm run api:report:update && api-documenter markdown --input temp/root --output docs/api",
    "docs:check": "pnpm run api:check && node scripts/verify-api-docs.mjs",
    "package:lint": "publint && attw --pack . --profile esm-only",
    "content:check": "node scripts/verify-public-content.mjs",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test:coverage && pnpm run build && pnpm run docs:check && pnpm run package:lint && pnpm run content:check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/api-documenter": "7.30.7",
    "@microsoft/api-extractor": "7.58.9",
    "@arethetypeswrong/cli": "0.18.5",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "typescript": "^7.0.2",
    "vitest": "4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/global-torque/client-error-handling.git"
  },
  "homepage": "https://github.com/global-torque/client-error-handling#readme",
  "bugs": {
    "url": "https://github.com/global-torque/client-error-handling/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "docs/api",
    "etc/client-error-handling.api.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dedupe": {
      "types": "./dist/dedupe.d.ts",
      "import": "./dist/dedupe.js"
    },
    "./normalize": {
      "types": "./dist/normalize.d.ts",
      "import": "./dist/normalize.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline.d.ts",
      "import": "./dist/pipeline.js"
    },
    "./reporter": {
      "types": "./dist/reporter.d.ts",
      "import": "./dist/reporter.js"
    },
    "./sanitize": {
      "types": "./dist/sanitize.d.ts",
      "import": "./dist/sanitize.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  }
}
