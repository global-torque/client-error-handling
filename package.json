{
  "name": "@global-torque/client-error-handling",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/global-torque/client-error-handling.git"
  },
  "homepage": "https://github.com/global-torque/client-error-handling#readme",
  "bugs": {
    "url": "https://github.com/global-torque/client-error-handling/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dedupe": {
      "types": "./dist/dedupe.d.ts",
      "import": "./dist/dedupe.js"
    },
    "./normalize": {
      "types": "./dist/normalize.d.ts",
      "import": "./dist/normalize.js"
    },
    "./reporter": {
      "types": "./dist/reporter.d.ts",
      "import": "./dist/reporter.js"
    },
    "./sanitize": {
      "types": "./dist/sanitize.d.ts",
      "import": "./dist/sanitize.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
